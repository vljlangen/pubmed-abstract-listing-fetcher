{
  "name": "pubmed-abstract-listing",
  "version": "1.0.0",
  "private": true,
  "description": "Static site + Netlify function for PubMed abstract listings.",
  "author": "Ville Langén",
  "main": "electron/main.js",
  "scripts": {
    "build": "node -e \"console.log('No compile step; publishing public/ as-is.')\"",
    "electron": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win portable --x64",
    "dist:mac-x64": "electron-builder --mac dmg zip --x64",
    "dist:mac-universal": "electron-builder --mac dmg zip --universal"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "fi.langen.pubmedAbstractListingFetcher",
    "productName": "PubMed Abstract Listing Fetcher",
    "copyright": "Copyright © 2026 Ville Langén",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "**/*",
      "!dist-electron/**",
      "!old_stuff/**",
      "!**/.git/**",
      "!**/.github/**",
      "!pubmed_abstracts_netlify.js",
      "!**/*.docx",
      "!public/**",
      "!docs/**",
      "!scripts/**",
      "!netlify/**",
      "!netlify.toml"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "PubMed Abstract Listing Fetcher"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "archiver": "^8.0.0"
  }
}
